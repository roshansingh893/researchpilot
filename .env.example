OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Gradio → FastAPI integration (Phase 2)
FASTAPI_BASE_URL=http://127.0.0.1:8000

# Document ingestion (Phase 4)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Embeddings & retrieval (Phase 5)
# To use OpenAI embeddings, set EMBEDDING_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_COLLECTION_NAME=researchpilot_chunks
RETRIEVAL_TOP_K=5

# RAG / LLM generation
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
# To use OpenAI LLM instead, set:
# LLM_PROVIDER=openai
# OPENAI_LLM_MODEL=gpt-4o-mini

# Conversational memory (Phase 7)
MEMORY_WINDOW=5

# Agentic research (Phase 8)
RESEARCH_RELEVANCE_THRESHOLD=0.25
